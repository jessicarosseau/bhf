---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroScene from "../components/HeroScene.astro";
import FarmStatus from "../components/FarmStatus.astro";
import SocialSpotlight from "../components/SocialSpotlight.astro";
import PreviewCard from "../components/PreviewCard.astro";
import Placeholder from "../components/Placeholder.astro";
import Icon from "../components/Icon.astro";
import { farm, mapDirectionsUrl, mapEmbedUrl, fullAddress } from "../data/farm";
import { href } from "../lib/url";

const quickFacts = [
  { icon: "map-pin", label: "Where", value: `${farm.address.town}, ${farm.address.state}`, sub: farm.directionsNote },
  { icon: "clock", label: "Season", value: farm.season.label, sub: "Weather-dependent — check social" },
  { icon: "basket", label: "Picking", value: "Pick-your-own", sub: farm.payment.pricingNote },
  { icon: "car", label: "Getting here", value: "Free on-site parking", sub: "~20 min up from Great Barrington" },
] as const;

const previews = [
  { title: "About Us", description: "A family farm on Mt. Washington, growing heirloom blueberries since 1941.", path: "/about", cta: "Our story", tone: "berry", icon: "leaf", label: "Family photo coming soon" },
  { title: "Cookbook", description: "Blueberry recipes for breakfast, dessert, drinks, preserves, and more.", path: "/cookbook", cta: "Browse recipes", tone: "sun", icon: "basket", label: "Recipe photo coming soon" },
  { title: "Gallery", description: "The rows, the ridgelines, and the little moments of a Berkshire summer.", path: "/gallery", cta: "See the farm", tone: "sky", icon: "camera", label: "Gallery photo coming soon" },
  { title: "Around Us", description: "Where to eat, hike, and wander while you're in the southern Berkshires.", path: "/around", cta: "Explore nearby", tone: "leaf", icon: "map-pin", label: "Berkshires photo coming soon" },
] as const;
---

<BaseLayout
  title="Home"
  description={farm.shortDescription}
  path="/"
>
  <!-- ── Hero ─────────────────────────────────────────────────────── -->
  <section class="hero">
    <HeroScene class="hero__scene" />
    <div class="hero__overlay"></div>
    <div class="container hero__inner">
      <div class="hero__copy">
        <p class="eyebrow hero__eyebrow">Pick-your-own · The Berkshires</p>
        <h1>Sun-warmed blueberries, high on Mt.&nbsp;Washington.</h1>
        <p class="lead hero__lead">
          A quiet, family-run farm in the southern Berkshires where you can pick
          heirloom highbush blueberries by the bucket — with three-state views
          thrown in for free.
        </p>
        <div class="flow-cta">
          <a class="btn btn--sun" href={href("/info")}>
            <Icon name="map-pin" size={18} /> Plan Your Visit
          </a>
          <a class="btn btn--ghost hero__ghost" href={farm.social.instagram.url} target="_blank" rel="noopener">
            <Icon name="instagram" size={18} /> Latest updates
          </a>
        </div>
      </div>

      <div class="hero__status">
        <FarmStatus variant="card" />
      </div>
    </div>
  </section>

  <!-- ── Quick facts ──────────────────────────────────────────────── -->
  <section class="section section--tight section--paper">
    <div class="container">
      <ul class="facts grid grid--4">
        {
          quickFacts.map((f) => (
            <li class="fact">
              <span class="fact__icon"><Icon name={f.icon} size={22} /></span>
              <span class="fact__label">{f.label}</span>
              <span class="fact__value">{f.value}</span>
              <span class="fact__sub">{f.sub}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ── Intro / welcome ──────────────────────────────────────────── -->
  <section class="section section--cream">
    <div class="container welcome">
      <div class="welcome__text">
        <p class="eyebrow">Welcome to the farm</p>
        <h2>A short season, a long tradition.</h2>
        <p class="lead">
          Blueberry Hill Farm has been part of Mt. Washington — the smallest
          town in Massachusetts — since Robert W. Austin planted the first
          bushes in 1941. Up here at elevation our berries ripen a week or two
          later than the valley, on old-fashioned varieties you won't find in a
          grocery store.
        </p>
        <p>
          Bring the family, grab a bucket at check-in, and take your time in the
          rows. When you're done, we'll weigh you out and send you home with the
          best blueberries you'll taste all summer.
        </p>
        <div class="flow-cta">
          <a class="btn btn--primary" href={href("/about")}>
            Meet the family <Icon name="arrow-right" size={17} />
          </a>
          <a class="btn btn--ghost" href={href("/info")}>Before you visit</a>
        </div>
      </div>
      <div class="welcome__media">
        <Placeholder ratio="4 / 5" tone="leaf" icon="leaf" label="Family / farm photo coming soon" />
        <span class="welcome__caption">
          <Icon name="camera" size={15} /> A favorite family photo will live here.
        </span>
      </div>
    </div>
  </section>

  <!-- ── Social spotlight ─────────────────────────────────────────── -->
  <SocialSpotlight class="section" />

  <!-- ── Explore previews ─────────────────────────────────────────── -->
  <section class="section section--cream">
    <div class="container">
      <div class="section-head center measure">
        <p class="eyebrow" style="justify-content:center">Explore the site</p>
        <h2>Everything you need for a good visit</h2>
        <p class="lead">
          From our family's story to a summer's worth of blueberry recipes and a
          local guide to the southern Berkshires.
        </p>
      </div>
      <div class="grid grid--2 previews">
        {previews.map((p) => <PreviewCard {...p} />)}
      </div>
    </div>
  </section>

  <!-- ── Directions / map ─────────────────────────────────────────── -->
  <section class="section section--paper">
    <div class="container directions">
      <div class="directions__text">
        <p class="eyebrow">Find us</p>
        <h2>Up the mountain, worth the drive.</h2>
        <p class="lead">{farm.directionsNote}</p>
        <address class="directions__address">
          <Icon name="map-pin" size={18} /> {fullAddress}
        </address>
        <p>{farm.season.note}</p>
        <div class="flow-cta">
          <a class="btn btn--primary" href={mapDirectionsUrl} target="_blank" rel="noopener">
            <Icon name="map-pin" size={18} /> Get Directions
          </a>
          <a class="btn btn--ghost" href={href("/info")}>Full visitor info</a>
        </div>
      </div>
      <div class="directions__map card">
        <iframe
          title={`Map showing ${farm.name} in ${farm.address.town}, ${farm.address.state}`}
          src={mapEmbedUrl}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    isolation: isolate;
    color: #fff;
    overflow: hidden;
  }
  .hero__scene {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -2;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      100deg,
      rgba(30, 29, 69, 0.82) 0%,
      rgba(30, 29, 69, 0.55) 42%,
      rgba(30, 29, 69, 0.15) 70%,
      transparent 100%
    );
  }
  @media (max-width: 60rem) {
    .hero__overlay {
      background: linear-gradient(
        180deg,
        rgba(30, 29, 69, 0.85) 0%,
        rgba(30, 29, 69, 0.6) 55%,
        rgba(30, 29, 69, 0.7) 100%
      );
    }
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    padding-block: clamp(3.5rem, 9vw, 7rem);
  }
  .hero__eyebrow {
    color: #f2c983;
  }
  .hero__eyebrow::before {
    background: var(--c-sun);
    box-shadow: 0 0 0 3px rgba(232, 161, 58, 0.25);
  }
  .hero h1 {
    color: #fff;
    max-width: 16ch;
    text-shadow: 0 2px 24px rgba(20, 19, 46, 0.4);
  }
  .hero__lead {
    color: #e7e4f4;
    max-width: 46ch;
    margin-bottom: 1.75rem;
  }
  .hero__ghost {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.55);
  }
  .hero__ghost:hover {
    background: rgba(255, 255, 255, 0.14);
    border-color: #fff;
    color: #fff;
  }
  @media (max-width: 60rem) {
    .hero__inner {
      grid-template-columns: 1fr;
    }
    .hero__status {
      max-width: 34rem;
    }
  }

  /* Quick facts */
  .facts {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .fact {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.25rem 0;
    margin: 0;
  }
  .fact__icon {
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background: var(--c-berry-soft);
    color: var(--c-berry);
    margin-bottom: 0.55rem;
  }
  .fact__label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-muted);
  }
  .fact__value {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--c-berry-deep);
  }
  .fact__sub {
    font-size: 0.88rem;
    color: var(--c-ink-soft);
  }

  /* Welcome */
  .welcome {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .welcome__media {
    position: relative;
  }
  .welcome__media :global(.ph) {
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
  }
  .welcome__caption {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.7rem;
    font-size: 0.82rem;
    color: var(--c-muted);
  }
  @media (max-width: 52rem) {
    .welcome {
      grid-template-columns: 1fr;
    }
    .welcome__media {
      order: -1;
      max-width: 22rem;
    }
  }

  .section-head {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .previews {
    align-items: stretch;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  @media (max-width: 40rem) {
    .previews {
      grid-template-columns: 1fr;
    }
  }

  /* Directions */
  .directions {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .directions__address {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-style: normal;
    font-weight: 600;
    color: var(--c-berry-deep);
    margin: 1rem 0;
  }
  .directions__map {
    padding: 0.5rem;
    height: 100%;
    min-height: 20rem;
    background: var(--c-berry-soft);
  }
  .directions__map iframe {
    width: 100%;
    height: 100%;
    min-height: 19rem;
    border: 0;
    border-radius: var(--radius-sm);
    display: block;
    background: var(--c-berry-soft);
  }
  @media (max-width: 52rem) {
    .directions {
      grid-template-columns: 1fr;
    }
  }
</style>
