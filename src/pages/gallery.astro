---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Placeholder from "../components/Placeholder.astro";
import Icon from "../components/Icon.astro";
import { href } from "../lib/url";
import {
  galleryCategories,
  galleryItems,
  type GalleryCategory,
} from "../data/gallery";

const usedCategories = (
  Object.keys(galleryCategories) as GalleryCategory[]
).filter((c) => galleryItems.some((i) => i.category === c));

const toneFor: Record<GalleryCategory, "berry" | "leaf" | "sky" | "sun"> = {
  berries: "berry",
  season: "sun",
  landscapes: "sky",
  history: "sky",
  family: "leaf",
  community: "leaf",
};
---

<BaseLayout
  title="Gallery"
  description="Photos from Blueberry Hill Farm — the berries, the picking season, Berkshire landscapes, farm history, and family moments on Mt. Washington."
  path="/gallery"
>
  <PageHeader
    eyebrow="Gallery"
    title="A Berkshire summer, in pictures"
    intro="The rows, the ridgelines, and the small moments of the season. More photos are added as we take them."
  />

  <section class="section">
    <div class="container">
      <div class="filter-row" role="group" aria-label="Filter photos by category">
        <button class="filter is-active" data-filter="all">All</button>
        {
          usedCategories.map((c) => (
            <button class="filter" data-filter={c}>{galleryCategories[c]}</button>
          ))
        }
      </div>

      <ul class="gallery" id="gallery">
        {
          galleryItems.map((item, i) => (
            <li class="gallery__item" data-category={item.category}>
              <button
                class="gallery__btn"
                data-index={i}
                aria-label={`View larger: ${item.caption}`}
              >
                {item.src ? (
                  <img
                    src={href(item.src)}
                    alt={item.alt}
                    loading="lazy"
                    decoding="async"
                    style={`aspect-ratio:${item.ratio ?? "4 / 3"}`}
                  />
                ) : (
                  <Placeholder
                    ratio={item.ratio ?? "4 / 3"}
                    tone={toneFor[item.category]}
                    icon="camera"
                    label={galleryCategories[item.category]}
                  />
                )}
                <span class="gallery__caption">
                  <span>{item.caption}</span>
                  <Icon name="arrow-up-right" size={15} />
                </span>
              </button>
            </li>
          ))
        }
      </ul>

      <p class="gallery-note">
        <Icon name="info" size={16} />
        These are styled placeholders. Real photographs will replace them —
        each keeps its caption and descriptive alt text for accessibility.
      </p>
    </div>
  </section>

  <!-- Lightbox -->
  <dialog id="lightbox" class="lightbox" aria-label="Photo viewer">
    <button class="lightbox__close" id="lb-close" aria-label="Close photo viewer">
      <Icon name="close" size={22} />
    </button>
    <button class="lightbox__nav lightbox__nav--prev" id="lb-prev" aria-label="Previous photo">
      <Icon name="arrow-right" size={26} />
    </button>
    <figure class="lightbox__figure">
      <div class="lightbox__media" id="lb-media"></div>
      <figcaption class="lightbox__caption" id="lb-caption"></figcaption>
    </figure>
    <button class="lightbox__nav lightbox__nav--next" id="lb-next" aria-label="Next photo">
      <Icon name="arrow-right" size={26} />
    </button>
  </dialog>

  <script is:inline define:vars={{ items: galleryItems, base: href("/") }}>
    (function () {
      const grid = document.getElementById("gallery");
      const filters = document.querySelectorAll(".filter");
      const dialog = document.getElementById("lightbox");
      const media = document.getElementById("lb-media");
      const caption = document.getElementById("lb-caption");
      const tones = {
        berries: "#4b4e9e",
        season: "#c07d1f",
        landscapes: "#5d7796",
        history: "#5d7796",
        family: "#4b7a54",
        community: "#4b7a54",
      };

      let order = items.map((_, i) => i); // current visible order
      let pos = 0;

      function joinBase(src) {
        const b = base.endsWith("/") ? base.slice(0, -1) : base;
        return src.startsWith("/") ? b + src : src;
      }

      function renderSlide(idx) {
        const item = items[idx];
        caption.textContent = item.caption;
        if (item.src) {
          media.innerHTML =
            '<img src="' +
            joinBase(item.src) +
            '" alt="' +
            item.alt.replace(/"/g, "&quot;") +
            '">';
        } else {
          media.innerHTML =
            '<div class="lightbox__ph" style="background:linear-gradient(150deg,' +
            (tones[item.category] || "#4b4e9e") +
            '33,' +
            (tones[item.category] || "#4b4e9e") +
            '11)"><span>' +
            item.alt +
            "</span><small>Photo coming soon</small></div>";
        }
      }

      function open(originalIndex) {
        pos = order.indexOf(originalIndex);
        if (pos < 0) pos = 0;
        renderSlide(order[pos]);
        if (typeof dialog.showModal === "function") dialog.showModal();
      }
      function step(delta) {
        pos = (pos + delta + order.length) % order.length;
        renderSlide(order[pos]);
      }

      grid.querySelectorAll(".gallery__btn").forEach((btn) => {
        btn.addEventListener("click", () =>
          open(parseInt(btn.dataset.index, 10))
        );
      });

      document.getElementById("lb-prev").addEventListener("click", () => step(-1));
      document.getElementById("lb-next").addEventListener("click", () => step(1));
      document
        .getElementById("lb-close")
        .addEventListener("click", () => dialog.close());
      dialog.addEventListener("click", (e) => {
        if (e.target === dialog) dialog.close();
      });
      document.addEventListener("keydown", (e) => {
        if (!dialog.open) return;
        if (e.key === "ArrowLeft") step(-1);
        if (e.key === "ArrowRight") step(1);
      });

      filters.forEach((btn) => {
        btn.addEventListener("click", () => {
          filters.forEach((b) => b.classList.remove("is-active"));
          btn.classList.add("is-active");
          const f = btn.dataset.filter;
          order = [];
          grid.querySelectorAll(".gallery__item").forEach((li, i) => {
            const show = f === "all" || li.dataset.category === f;
            li.hidden = !show;
            if (show) order.push(i);
          });
        });
      });
    })();
  </script>
</BaseLayout>

<style>
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.75rem;
  }
  .filter {
    padding: 0.5rem 1rem;
    border-radius: var(--radius);
    border: 1.5px solid var(--line);
    background: var(--white);
    color: var(--ink-2);
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.18s ease;
  }
  .filter:hover {
    border-color: var(--indigo);
    color: var(--indigo-deep);
  }
  .filter.is-active {
    background: var(--indigo);
    border-color: var(--indigo);
    color: #fff;
  }

  /* Masonry via CSS columns */
  .gallery {
    list-style: none;
    padding: 0;
    margin: 0;
    columns: 3 16rem;
    column-gap: 1rem;
  }
  .gallery__item {
    break-inside: avoid;
    margin: 0 0 1rem;
  }
  .gallery__btn {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .gallery__btn img,
  .gallery__btn :global(.ph) {
    width: 100%;
    object-fit: cover;
    display: block;
    border-radius: var(--radius);
    transition: transform 0.4s ease;
  }
  .gallery__btn:hover img,
  .gallery__btn:hover :global(.ph) {
    transform: scale(1.05);
  }
  .gallery__caption {
    position: absolute;
    inset: auto 0 0 0;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 1.5rem 0.9rem 0.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    text-align: left;
    color: #fff;
    background: linear-gradient(transparent, rgba(20, 19, 46, 0.82));
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .gallery__btn:hover .gallery__caption,
  .gallery__btn:focus-visible .gallery__caption {
    opacity: 1;
    transform: translateY(0);
  }
  .gallery__caption :global(svg) {
    flex-shrink: 0;
  }

  .gallery-note {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
    max-width: 52ch;
    margin: 2rem auto 0;
    font-size: 0.85rem;
    color: var(--ink-3);
  }
  .gallery-note :global(svg) {
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  /* Lightbox */
  .lightbox {
    padding: 0;
    border: none;
    background: transparent;
    max-width: 100vw;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    margin: 0;
    overflow: hidden;
  }
  .lightbox::backdrop {
    background: rgba(20, 19, 46, 0.9);
    backdrop-filter: blur(4px);
  }
  .lightbox[open] {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }
  .lightbox__figure {
    margin: 0;
    max-width: min(60rem, 92vw);
    max-height: 88vh;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .lightbox__media {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 0;
  }
  .lightbox__media :global(img) {
    max-width: 100%;
    max-height: 78vh;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }
  .lightbox__media :global(.lightbox__ph) {
    width: min(46rem, 88vw);
    aspect-ratio: 4 / 3;
    max-height: 74vh;
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    text-align: center;
    padding: 2rem;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }
  .lightbox__media :global(.lightbox__ph span) {
    font-family: var(--font-display);
    font-size: 1.3rem;
    max-width: 24ch;
  }
  .lightbox__media :global(.lightbox__ph small) {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.8;
  }
  .lightbox__caption {
    color: #ece9f6;
    text-align: center;
    font-size: 0.95rem;
  }
  .lightbox__close,
  .lightbox__nav {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.14);
    color: #fff;
    cursor: pointer;
    flex-shrink: 0;
    transition: background-color 0.18s ease;
  }
  .lightbox__close:hover,
  .lightbox__nav:hover {
    background: rgba(255, 255, 255, 0.28);
  }
  .lightbox__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
  }
  .lightbox__nav--prev :global(svg) {
    transform: rotate(180deg);
  }
  @media (max-width: 40rem) {
    .lightbox__nav {
      position: absolute;
      bottom: 1rem;
      z-index: 2;
    }
    .lightbox__nav--prev {
      left: 1rem;
    }
    .lightbox__nav--next {
      right: 1rem;
    }
  }
</style>
