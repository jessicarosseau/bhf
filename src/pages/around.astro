---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Icon from "../components/Icon.astro";
import { aroundSections, itineraries } from "../data/around";
import { href } from "../lib/url";
---

<BaseLayout
  title="Around Us"
  description="A local guide to the southern Berkshires near Blueberry Hill Farm — where to eat, hike, shop, and stay around Great Barrington, Mt. Washington, and Sheffield."
  path="/around"
>
  <PageHeader
    eyebrow="Around us"
    title="Make a day of it in the Berkshires"
    intro="A short, honest list of favorites near the farm — from waterfalls and summits to Main Street coffee. Pair it with a morning of picking."
    tone="leaf"
  />

  <!-- Section quick-nav -->
  <nav class="jumpnav" aria-label="Guide sections">
    <div class="container jumpnav__inner">
      {aroundSections.map((s) => <a href={`#${s.id}`}>{s.title}</a>)}
      <a href="#itineraries">Itineraries</a>
    </div>
  </nav>

  <div class="section">
    <div class="container">
      <p class="disclaimer callout">
        <Icon name="info" size={18} />
        <span>
          These are independent businesses and public parks — they set their own
          hours and can change or close. Please check their websites before you go.
        </span>
      </p>

      {
        aroundSections.map((section) => (
          <section id={section.id} class="around-section">
            <div class="around-section__head">
              <span class="around-section__icon"><Icon name={section.icon} size={22} /></span>
              <div>
                <h2>{section.title}</h2>
                <p>{section.intro}</p>
              </div>
            </div>
            <div class="grid grid--2">
              {section.places.map((p) => (
                <div class="place card">
                  <div class="place__body">
                    <div class="place__head">
                      <h3>{p.name}</h3>
                      <span class="place__town"><Icon name="map-pin" size={14} /> {p.town}</span>
                    </div>
                    <p>{p.description}</p>
                    {p.note && <span class="place__note">{p.note}</span>}
                  </div>
                  {p.url && (
                    <a class="place__link" href={p.url} target="_blank" rel="noopener">
                      Visit website <Icon name="arrow-up-right" size={15} />
                    </a>
                  )}
                </div>
              ))}
            </div>
          </section>
        ))
      }

      <!-- Itineraries -->
      <section id="itineraries" class="around-section">
        <div class="around-section__head">
          <span class="around-section__icon"><Icon name="sun" size={22} /></span>
          <div>
            <h2>Suggested itineraries</h2>
            <p>Two easy ways to build a day around a visit to the farm.</p>
          </div>
        </div>
        <div class="grid grid--2">
          {
            itineraries.map((it) => (
              <div class="itinerary card">
                <h3>{it.title}</h3>
                <ol>
                  {it.steps.map((s) => <li>{s}</li>)}
                </ol>
              </div>
            ))
          }
        </div>
      </section>
    </div>
  </div>

  <section class="section section--tight section--berry">
    <div class="container center measure">
      <h2>Start with the berries</h2>
      <p class="lead">However you spend the day, begin it in the rows while the morning's still cool.</p>
      <div class="flow-cta" style="justify-content:center">
        <a class="btn btn--sun" href={href("/info")}><Icon name="map-pin" size={18} /> Plan Your Visit</a>
        <a class="btn btn--ghost" href={href("/cookbook")}>Blueberry recipes</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .jumpnav {
    position: sticky;
    top: 4.5rem;
    z-index: 50;
    background: color-mix(in srgb, var(--c-cream) 92%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--c-line);
  }
  .jumpnav__inner {
    display: flex;
    gap: 0.4rem;
    overflow-x: auto;
    padding-block: 0.6rem;
    scrollbar-width: none;
  }
  .jumpnav__inner::-webkit-scrollbar {
    display: none;
  }
  .jumpnav a {
    flex-shrink: 0;
    padding: 0.4rem 0.85rem;
    border-radius: var(--radius-pill);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--c-ink-soft);
    text-decoration: none;
    white-space: nowrap;
  }
  .jumpnav a:hover {
    background: var(--c-leaf-soft);
    color: var(--c-leaf-dark);
  }

  .disclaimer {
    background: var(--c-leaf-soft);
    color: var(--c-leaf-dark);
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    padding: 0.9rem 1.1rem;
    border-radius: var(--radius-sm);
    margin-bottom: 2.5rem;
  }
  .disclaimer :global(svg) {
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .around-section {
    margin-bottom: clamp(2.5rem, 5vw, 3.75rem);
    scroll-margin-top: 8rem;
  }
  .around-section__head {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }
  .around-section__icon {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    flex-shrink: 0;
    border-radius: 50%;
    background: var(--c-leaf-soft);
    color: var(--c-leaf-dark);
  }
  .around-section__head h2 {
    margin: 0 0 0.15rem;
  }
  .around-section__head p {
    color: var(--c-ink-soft);
    margin: 0;
  }

  .place {
    display: flex;
    flex-direction: column;
    padding: 1.3rem 1.4rem;
  }
  .place__body {
    flex: 1;
  }
  .place__head {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
  }
  .place__head h3 {
    margin: 0;
    font-size: 1.2rem;
  }
  .place__town {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--c-leaf-dark);
    white-space: nowrap;
  }
  .place p {
    color: var(--c-ink-soft);
    font-size: 0.95rem;
  }
  .place__note {
    display: inline-block;
    margin-top: 0.6rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--c-soon);
    background: var(--c-sun-soft);
    padding: 0.2rem 0.55rem;
    border-radius: var(--radius-pill);
  }
  .place__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.9rem;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--c-berry-dark);
    text-decoration: none;
  }
  .place__link:hover {
    text-decoration: underline;
  }

  .itinerary {
    padding: 1.5rem 1.6rem;
  }
  .itinerary h3 {
    margin-bottom: 0.9rem;
  }
  .itinerary ol {
    margin: 0;
    padding-left: 1.2rem;
    display: grid;
    gap: 0.55rem;
  }
  .itinerary li {
    color: var(--c-ink-soft);
    padding-left: 0.3rem;
  }
  .itinerary li::marker {
    color: var(--c-leaf);
    font-weight: 700;
  }
</style>
