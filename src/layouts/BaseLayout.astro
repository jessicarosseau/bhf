---
import "../styles/global.css";
import SEO from "../components/SEO.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  noindex?: boolean;
}
const { title, description, path, image, noindex } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEO
      title={title}
      description={description}
      path={path}
      image={image}
      noindex={noindex}
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to main content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    height: 100%;
  }
  body {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
  }
  main {
    flex: 1 0 auto;
  }
</style>
