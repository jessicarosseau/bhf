---
/**
 * Inline SVG icon set. Icons are decorative by default (aria-hidden);
 * pass a `title` to give an icon an accessible label.
 * Line icons use currentColor; brand icons (instagram/facebook) are filled.
 */
interface Props {
  name: keyof typeof paths;
  size?: number | string;
  class?: string;
  title?: string;
}
const { name, size = 24, class: className = "", title } = Astro.props;

const paths = {
  "arrow-right": '<path d="M5 12h14M13 6l6 6-6 6"/>',
  "arrow-up-right": '<path d="M7 17 17 7M8 7h9v9"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  "map-pin":
    '<path d="M20 10c0 5.5-8 12-8 12s-8-6.5-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="2.8"/>',
  phone:
    '<path d="M5 4h3.5l1.6 4.2-2.1 1.4a12 12 0 0 0 5.4 5.4l1.4-2.1L18.4 16V19a1.5 1.5 0 0 1-1.6 1.5A15.5 15.5 0 0 1 3.5 6.6 1.5 1.5 0 0 1 5 4Z"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2.5"/><path d="m3.5 7 8.5 6 8.5-6"/>',
  sun: '<circle cx="12" cy="12" r="4.2"/><path d="M12 2.5v2.2M12 19.3v2.2M4.4 4.4l1.6 1.6M18 18l1.6 1.6M2.5 12h2.2M19.3 12h2.2M4.4 19.6 6 18M18 6l1.6-1.6"/>',
  leaf: '<path d="M4 20c0-8 5-14 16-14 0 11-6 16-14 16"/><path d="M4 20c4-6 8-8 12-9"/>',
  check: '<path d="m5 12.5 4.5 4.5L19 7"/>',
  close: '<path d="M6 6l12 12M18 6 6 18"/>',
  info: '<circle cx="12" cy="12" r="9"/><path d="M12 11v5M12 7.6v.2"/>',
  car: '<path d="M4 16v-3l2-5.5A2 2 0 0 1 7.9 6h8.2a2 2 0 0 1 1.9 1.5L20 13v3"/><path d="M4 16h16v2.5a1 1 0 0 1-1 1h-2v-3.5M7 19.5V16M4 13h16"/><circle cx="7.5" cy="16.5" r="1"/><circle cx="16.5" cy="16.5" r="1"/>',
  basket:
    '<path d="M4 9h16l-1.3 9.2a2 2 0 0 1-2 1.8H7.3a2 2 0 0 1-2-1.8L4 9Z"/><path d="M8.5 9 12 3.5 15.5 9"/><path d="M9.5 13v3M14.5 13v3"/>',
  camera:
    '<path d="M4 8h3l1.5-2h7L17 8h3a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1Z"/><circle cx="12" cy="13" r="3.2"/>',
  accessibility:
    '<circle cx="12" cy="4" r="1.6"/><path d="M5 8.5c2 .8 4.4 1.2 7 1.2s5-.4 7-1.2M12 9.7V15m0 0-2.5 5.5M12 15l2.5 5.5"/>',
  paw: '<circle cx="7" cy="10" r="1.7"/><circle cx="12" cy="8" r="1.8"/><circle cx="17" cy="10" r="1.7"/><path d="M12 12c-2.6 0-4.7 1.9-4.7 4 0 1.4 1.3 2 2.4 1.6 1.5-.6 3.1-.6 4.6 0 1.1.4 2.4-.2 2.4-1.6 0-2.1-2.1-4-4.7-4Z"/>',
  print:
    '<path d="M7 9V4h10v5"/><rect x="4" y="9" width="16" height="7" rx="1.5"/><path d="M7 14h10v6H7z"/><path d="M16.5 12h.2"/>',
  instagram:
    '<rect x="3.2" y="3.2" width="17.6" height="17.6" rx="5"/><circle cx="12" cy="12" r="4.1"/><circle cx="17.2" cy="6.8" r="1.2" fill="currentColor" stroke="none"/>',
  facebook:
    '<path d="M14.5 8.5V6.8c0-.8.5-1 .9-1H17V2.6h-2.4c-2.7 0-3.6 1.9-3.6 3.8v2.1H9v3h2v9h3.5v-9H17l.5-3h-3Z" fill="currentColor" stroke="none"/>',
} as const;

// Facebook is a solid glyph (filled); Instagram uses outlined strokes like the
// line icons, with just its lens-dot filled inline.
const isFilled = name === "facebook";
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={isFilled ? "currentColor" : "none"}
  stroke={isFilled ? "none" : "currentColor"}
  stroke-width={isFilled ? "0" : "1.8"}
  stroke-linecap="round"
  stroke-linejoin="round"
  role={title ? "img" : undefined}
  aria-hidden={title ? undefined : "true"}
  aria-label={title}
  focusable="false"
  set:html={(title ? `<title>${title}</title>` : "") + paths[name]}
/>
