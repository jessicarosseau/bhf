---
import { navLinks } from "../data/nav";
import { farm } from "../data/farm";
import { href, isActive } from "../lib/url";
import BerryMark from "./BerryMark.astro";
import Icon from "./Icon.astro";

const current = Astro.url.pathname;
---

<header class="site-header" id="site-header">
  <div class="container site-header__inner">
    <a class="brand" href={href("/")} aria-label={`${farm.name} — home`}>
      <BerryMark size={38} class="brand__mark" />
      <span class="brand__word">
        <span class="brand__name">Blueberry Hill</span>
        <span class="brand__sub">Farm · The Berkshires</span>
      </span>
    </a>

    <nav class="nav" aria-label="Primary">
      <button
        class="nav__toggle"
        id="nav-toggle"
        aria-expanded="false"
        aria-controls="nav-menu"
      >
        <span class="nav__toggle-bars" aria-hidden="true"></span>
        <span class="sr-only">Menu</span>
      </button>

      <ul class="nav__menu" id="nav-menu">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={href(link.path)}
                class="nav__link"
                aria-current={isActive(current, link.path) ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
        <li class="nav__cta-item">
          <a class="btn btn--sm btn--primary" href={href("/info")}>
            <Icon name="map-pin" size={16} /> Plan Your Visit
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-menu");
  const header = document.getElementById("site-header");

  function setOpen(open: boolean) {
    if (!toggle || !header) return;
    toggle.setAttribute("aria-expanded", String(open));
    header.classList.toggle("is-open", open);
    document.body.classList.toggle("nav-open", open);
  }

  toggle?.addEventListener("click", () => {
    setOpen(toggle.getAttribute("aria-expanded") !== "true");
  });

  // Close when a link is chosen or Escape is pressed.
  menu?.addEventListener("click", (e) => {
    if ((e.target as HTMLElement).closest("a")) setOpen(false);
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") setOpen(false);
  });

  // Shadow on scroll.
  const onScroll = () =>
    header?.classList.toggle("is-scrolled", window.scrollY > 8);
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--c-cream) 88%, transparent);
    backdrop-filter: saturate(1.4) blur(10px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease, box-shadow 0.2s ease,
      background-color 0.2s ease;
  }
  .site-header.is-scrolled {
    border-bottom-color: var(--c-line);
    box-shadow: 0 4px 18px rgba(30, 29, 69, 0.06);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4.5rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: var(--c-berry-deep);
  }
  .brand__mark {
    flex-shrink: 0;
  }
  .brand__word {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }
  .brand__name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.3rem;
    letter-spacing: -0.01em;
  }
  .brand__sub {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--c-leaf-dark);
  }

  .nav__toggle {
    display: none;
  }
  .nav__menu {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav__link {
    display: inline-block;
    padding: 0.55rem 0.8rem;
    border-radius: var(--radius-pill);
    color: var(--c-ink);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background-color 0.18s ease, color 0.18s ease;
  }
  .nav__link:hover {
    background: var(--c-berry-soft);
    color: var(--c-berry-dark);
  }
  .nav__link[aria-current="page"] {
    color: var(--c-berry-dark);
    background: var(--c-berry-soft);
  }
  .nav__cta-item {
    margin-left: 0.4rem;
  }

  /* Mobile */
  @media (max-width: 56rem) {
    .nav__toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2.8rem;
      height: 2.8rem;
      border: 1px solid var(--c-line);
      border-radius: var(--radius-sm);
      background: var(--c-paper);
      cursor: pointer;
    }
    .nav__toggle-bars,
    .nav__toggle-bars::before,
    .nav__toggle-bars::after {
      content: "";
      display: block;
      width: 20px;
      height: 2px;
      background: var(--c-berry-deep);
      border-radius: 2px;
      transition: transform 0.22s ease, opacity 0.22s ease;
    }
    .nav__toggle-bars {
      position: relative;
    }
    .nav__toggle-bars::before {
      position: absolute;
      top: -6px;
    }
    .nav__toggle-bars::after {
      position: absolute;
      top: 6px;
    }
    .is-open .nav__toggle-bars {
      background: transparent;
    }
    .is-open .nav__toggle-bars::before {
      transform: translateY(6px) rotate(45deg);
    }
    .is-open .nav__toggle-bars::after {
      transform: translateY(-6px) rotate(-45deg);
    }

    .nav__menu {
      position: fixed;
      inset: 4.5rem 0 auto 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0.15rem;
      padding: 1rem clamp(1.1rem, 4vw, 2.5rem) 1.5rem;
      background: var(--c-cream);
      border-bottom: 1px solid var(--c-line);
      box-shadow: var(--shadow-lg);
      transform: translateY(-130%);
      transition: transform 0.28s ease;
      max-height: calc(100dvh - 4.5rem);
      overflow-y: auto;
    }
    .is-open .nav__menu {
      transform: translateY(0);
    }
    .nav__link {
      display: block;
      padding: 0.85rem 0.9rem;
      font-size: 1.05rem;
      border-radius: var(--radius-sm);
    }
    .nav__cta-item {
      margin: 0.6rem 0 0;
    }
    .nav__cta-item .btn {
      width: 100%;
      padding-block: 0.85rem;
    }
    :global(body.nav-open) {
      overflow: hidden;
    }
  }
</style>
