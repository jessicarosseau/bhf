---
import { navLinks } from "../data/nav";
import { farm, farmStatus } from "../data/farm";
import { href, isActive } from "../lib/url";
import BerryMark from "./BerryMark.astro";

const current = Astro.url.pathname;
const statusLabel = {
  open: "Open",
  closed: "Closed for the season",
  "opening-soon": "Opening soon",
  "closing-soon": "Season ending soon",
}[farmStatus.status];
---

<!-- Announcement / status strip -->
<div class="announce">
  <div class="container announce__inner">
    <span class="announce__status">{statusLabel}</span>
    <span class="announce__sep" aria-hidden="true">·</span>
    <span class="announce__hours">{farm.hours.summary}</span>
    <a class="announce__link" href={href("/info")}>Plan your visit &rsaquo;</a>
  </div>
</div>

<header class="hd" id="site-header">
  <div class="container hd__inner">
    <a class="brand" href={href("/")} aria-label={`${farm.name} — home`}>
      <BerryMark size={34} class="brand__mark" />
      <span class="brand__word">
        <span class="brand__name">Blueberry Hill Farm</span>
        <span class="brand__sub">Mt. Washington · The Berkshires</span>
      </span>
    </a>

    <nav class="nav" aria-label="Primary">
      <button
        class="nav__toggle"
        id="nav-toggle"
        aria-expanded="false"
        aria-controls="nav-menu"
      >
        <span class="nav__bars" aria-hidden="true"></span>
        <span class="sr-only">Menu</span>
      </button>

      <ul class="nav__menu" id="nav-menu">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={href(link.path)}
                class="nav__link"
                aria-current={isActive(current, link.path) ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
        <li class="nav__cta">
          <a class="btn btn--sm btn--ghost" href={href("/info")}>Plan a Visit</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-menu");
  const header = document.getElementById("site-header");

  function setOpen(open: boolean) {
    if (!toggle || !header) return;
    toggle.setAttribute("aria-expanded", String(open));
    header.classList.toggle("is-open", open);
    document.body.classList.toggle("nav-open", open);
  }
  toggle?.addEventListener("click", () =>
    setOpen(toggle.getAttribute("aria-expanded") !== "true")
  );
  menu?.addEventListener("click", (e) => {
    if ((e.target as HTMLElement).closest("a")) setOpen(false);
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") setOpen(false);
  });

  const onScroll = () =>
    header?.classList.toggle("is-scrolled", window.scrollY > 12);
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>

<style>
  .announce {
    background: var(--indigo-deep);
    color: #cfcde0;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
  }
  .announce__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    padding-block: 0.55rem;
    text-align: center;
  }
  .announce__status {
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
  }
  .announce__sep {
    opacity: 0.5;
  }
  .announce__link {
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
    padding-bottom: 1px;
  }
  .announce__link:hover {
    color: #fff;
    border-color: #fff;
  }

  .hd {
    position: sticky;
    top: 0;
    z-index: 100;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background-color 0.25s ease, border-color 0.25s ease,
      box-shadow 0.25s ease;
  }
  .hd.is-scrolled {
    background: color-mix(in srgb, var(--paper) 92%, transparent);
    backdrop-filter: saturate(1.3) blur(10px);
    border-bottom-color: var(--line);
  }
  .hd__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: var(--header-h);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: var(--ink);
  }
  .brand__word {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .brand__name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.28rem;
    letter-spacing: -0.01em;
  }
  .brand__sub {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-3);
  }

  .nav__toggle {
    display: none;
  }
  .nav__menu {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav__link {
    display: inline-block;
    color: var(--ink);
    font-weight: 600;
    font-size: 0.76rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    transition: border-color 0.18s ease, opacity 0.18s ease;
  }
  .nav__link:hover {
    opacity: 0.6;
  }
  .nav__link[aria-current="page"] {
    border-bottom-color: var(--ink);
  }
  .nav__cta {
    margin-left: 0.2rem;
  }

  /* Mobile: full-screen overlay */
  @media (max-width: 60rem) {
    .nav__toggle {
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 5px;
      width: 2.75rem;
      height: 2.75rem;
      border: none;
      background: transparent;
      cursor: pointer;
      z-index: 120;
    }
    .nav__bars,
    .nav__bars::before,
    .nav__bars::after {
      content: "";
      display: block;
      width: 24px;
      height: 1.5px;
      background: var(--ink);
      transition: transform 0.24s ease, opacity 0.24s ease;
    }
    .nav__bars {
      position: relative;
    }
    .nav__bars::before {
      position: absolute;
      top: -7px;
    }
    .nav__bars::after {
      position: absolute;
      top: 7px;
    }
    .is-open .nav__bars {
      background: transparent;
    }
    .is-open .nav__bars::before {
      transform: translateY(7px) rotate(45deg);
    }
    .is-open .nav__bars::after {
      transform: translateY(-7px) rotate(-45deg);
    }

    .nav__menu {
      position: fixed;
      inset: 0;
      flex-direction: column;
      justify-content: center;
      gap: 0.4rem;
      background: var(--paper);
      transform: translateX(100%);
      transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
      z-index: 110;
    }
    .is-open .nav__menu {
      transform: translateX(0);
    }
    .nav__link {
      font-family: var(--font-display);
      font-size: 2rem;
      font-weight: 400;
      letter-spacing: -0.01em;
      text-transform: none;
      padding: 0.6rem 0;
    }
    .nav__link[aria-current="page"] {
      border-bottom-color: transparent;
      font-style: italic;
    }
    .nav__cta {
      margin: 1.5rem 0 0;
    }
    :global(body.nav-open) {
      overflow: hidden;
    }
  }
</style>
