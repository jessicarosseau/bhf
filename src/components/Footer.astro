---
import { farm, fullAddress, mapDirectionsUrl } from "../data/farm";
import { navLinks } from "../data/nav";
import { href } from "../lib/url";
import BerryMark from "./BerryMark.astro";
import BotanicalSprig from "./BotanicalSprig.astro";
import Icon from "./Icon.astro";

const year = 2026; // update yearly if desired
---

<footer class="ft">
  <div class="container ft__top">
    <BotanicalSprig size={46} class="ft__sprig" />
    <p class="ft__tagline">{farm.tagline}</p>
    <div class="ft__social">
      <a href={farm.social.instagram.url} target="_blank" rel="noopener">
        <Icon name="instagram" size={18} /> Instagram
      </a>
      <a href={farm.social.facebook.url} target="_blank" rel="noopener">
        <Icon name="facebook" size={18} /> Facebook
      </a>
    </div>
  </div>

  <div class="container ft__grid">
    <div class="ft__brand">
      <a class="brand" href={href("/")} aria-label={`${farm.name} — home`}>
        <BerryMark size={30} />
        <span class="brand__word">
          <span class="brand__name">Blueberry Hill Farm</span>
          <span class="brand__sub">Est. 1941</span>
        </span>
      </a>
    </div>

    <nav class="ft__col" aria-label="Footer">
      <h2>Explore</h2>
      <ul>
        {navLinks.map((l) => <li><a href={href(l.path)}>{l.label}</a></li>)}
      </ul>
    </nav>

    <div class="ft__col">
      <h2>Visit</h2>
      <ul>
        <li><a href={mapDirectionsUrl} target="_blank" rel="noopener">{fullAddress}</a></li>
        <li>{farm.hours.summary}</li>
        <li class="ft__muted">{farm.season.label}</li>
      </ul>
    </div>

    <div class="ft__col">
      <h2>Contact</h2>
      <ul>
        <li><a href={`tel:${farm.phoneHref}`}>{farm.phone}</a></li>
        <li><a href={`mailto:${farm.email}`}>{farm.email}</a></li>
      </ul>
      <p class="ft__note">Hours change often — check social for the latest.</p>
    </div>
  </div>

  <div class="ft__bar">
    <div class="container ft__bar-inner">
      <p>© {year} {farm.legalEntity}</p>
      <p>Mt. Washington, Massachusetts</p>
    </div>
  </div>
</footer>

<style>
  .ft {
    background: var(--indigo-deep);
    color: #b7b3cf;
    margin-top: auto;
  }
  .ft a {
    color: #ddd9ee;
    text-decoration: none;
  }
  .ft a:hover {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .ft__top {
    text-align: center;
    padding-block: clamp(3rem, 6vw, 4.5rem) 2.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .ft__sprig {
    color: #7d78a6;
    margin: 0 auto 1.25rem;
  }
  .ft__tagline {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 1.1rem + 1.4vw, 2rem);
    font-style: italic;
    color: #fff;
    max-width: 24ch;
    margin: 0 auto 1.5rem;
    line-height: 1.3;
  }
  .ft__social {
    display: flex;
    justify-content: center;
    gap: 2rem;
  }
  .ft__social a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .ft__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1.4fr 1.2fr;
    gap: clamp(1.75rem, 4vw, 3.5rem);
    padding-block: clamp(2.75rem, 5vw, 4rem);
  }
  @media (max-width: 52rem) {
    .ft__grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.25rem;
    }
    .ft__brand {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 30rem) {
    .ft__grid {
      grid-template-columns: 1fr;
    }
  }

  .ft .brand {
    color: #fff;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .ft .brand__word {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .ft .brand__name {
    font-family: var(--font-display);
    font-size: 1.2rem;
  }
  .ft .brand__sub {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #8f8ab6;
  }

  .ft__col h2 {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #8f8ab6;
    margin: 0 0 1.1rem;
  }
  .ft__col ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .ft__col li {
    margin-bottom: 0.6rem;
    line-height: 1.5;
  }
  .ft__muted {
    color: #8f8ab6;
    font-size: 0.9rem;
  }
  .ft__note {
    margin-top: 1rem;
    font-size: 0.82rem;
    color: #8f8ab6;
    max-width: 30ch;
  }

  .ft__bar {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .ft__bar-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.4rem;
    padding-block: 1.3rem;
    font-size: 0.76rem;
    letter-spacing: 0.05em;
    color: #8f8ab6;
  }
  .ft__bar-inner p {
    margin: 0;
  }
</style>
