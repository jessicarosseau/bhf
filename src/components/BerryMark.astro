---
/**
 * The Blueberry Hill Farm brand mark — a single blueberry with a leaf.
 * Decorative; the accompanying wordmark carries the accessible name.
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 40, class: className = "" } = Astro.props;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  aria-hidden="true"
  focusable="false"
>
  <path
    d="M20.5 6.2c2.6-.6 4.9.4 4.9.4s-.2 2.5-2 4.1c-1.6 1.4-3.7 1.3-4.7 1.1-.2-1 .1-3.2 1.8-5.6z"
    fill="#4b7a54"></path>
  <path
    d="M18.9 11.7c1-2.4 3-4.1 4.9-5.1"
    stroke="#33553b"
    stroke-width="1"
    stroke-linecap="round"></path>
  <circle cx="14.5" cy="19" r="8.2" fill="#4b4e9e"></circle>
  <circle cx="14.5" cy="19" r="8.2" fill="url(#bhf-bloom)"></circle>
  <path
    d="M14.5 14.2l1.1 2.2 2.4.35-1.75 1.7.42 2.4-2.17-1.14-2.17 1.14.42-2.4-1.75-1.7 2.4-.35z"
    fill="#1e1d45"></path>
  <defs>
    <radialGradient id="bhf-bloom" cx="0.38" cy="0.32" r="0.75">
      <stop offset="0" stop-color="#a9b6d9" stop-opacity="0.55"></stop>
      <stop offset="0.55" stop-color="#a9b6d9" stop-opacity="0"></stop>
    </radialGradient>
  </defs>
</svg>
