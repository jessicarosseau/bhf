---
/**
 * The Blueberry Hill Farm mark — a single monoline blueberry with a leaf.
 * Inherits currentColor so it reads as ink on light surfaces and white on dark.
 * Decorative; the wordmark beside it carries the accessible name.
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 34, class: className = "" } = Astro.props;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  stroke="currentColor"
  stroke-width="1.4"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  <!-- leaf -->
  <path d="M17 9c1.4-3.2 4.3-5.2 7.6-5.6.2 3.3-1.3 6.4-4.2 8" />
  <!-- berry -->
  <circle cx="14.5" cy="19.5" r="8" />
  <!-- calyx star -->
  <path
    d="M14.5 15.4l1 2 2.2.3-1.6 1.5.4 2.2-2-1.05-2 1.05.4-2.2-1.6-1.5 2.2-.3z"
  />
</svg>
