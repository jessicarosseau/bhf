---
/**
 * Social spotlight — reminds visitors that Instagram & Facebook are the best
 * source for live hours, picking conditions, closures, and announcements.
 */
import { farm } from "../data/farm";
import Icon from "./Icon.astro";

interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<section class={`spotlight section--berry ${className}`} aria-labelledby="spotlight-title">
  <div class="container spotlight__inner">
    <div class="spotlight__text">
      <p class="eyebrow">The latest from the farm</p>
      <h2 id="spotlight-title">Follow along for today's picking conditions</h2>
      <p class="lead">
        Our season is short and the weather has the final say. The fastest way
        to know whether we're open, how the berries are coming in, and when we
        close for the day is right here:
      </p>
      <ul class="spotlight__list">
        <li><Icon name="check" size={18} /> Opening dates &amp; daily hours</li>
        <li><Icon name="check" size={18} /> Current picking conditions</li>
        <li><Icon name="check" size={18} /> Weather closures &amp; full-field days</li>
        <li><Icon name="check" size={18} /> Farm news &amp; announcements</li>
      </ul>
    </div>

    <div class="spotlight__cards">
      <a class="spotlight__card" href={farm.social.instagram.url} target="_blank" rel="noopener">
        <span class="spotlight__icon"><Icon name="instagram" size={26} /></span>
        <span class="spotlight__handle">{farm.social.instagram.handle}</span>
        <span class="spotlight__meta">Photos &amp; daily updates <Icon name="arrow-up-right" size={16} /></span>
      </a>
      <a class="spotlight__card" href={farm.social.facebook.url} target="_blank" rel="noopener">
        <span class="spotlight__icon"><Icon name="facebook" size={26} /></span>
        <span class="spotlight__handle">Blueberry Hill Farm</span>
        <span class="spotlight__meta">Announcements &amp; hours <Icon name="arrow-up-right" size={16} /></span>
      </a>
    </div>
  </div>
</section>

<style>
  .spotlight__inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  @media (max-width: 52rem) {
    .spotlight__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
  .spotlight__list {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }
  .spotlight__list li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0;
    color: #dcd8ee;
  }
  .spotlight__list :global(svg) {
    color: var(--c-bloom);
    flex-shrink: 0;
  }
  .spotlight__cards {
    display: grid;
    gap: 1rem;
  }
  .spotlight__card {
    display: grid;
    gap: 0.35rem;
    padding: 1.4rem 1.5rem;
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.14);
    text-decoration: none;
    color: #fff;
    transition: background-color 0.2s ease, transform 0.2s ease,
      border-color 0.2s ease;
  }
  .spotlight__card:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: var(--c-bloom);
    transform: translateY(-3px);
    text-decoration: none;
    color: #fff;
  }
  .spotlight__icon {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
  }
  .spotlight__handle {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
  }
  .spotlight__meta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.9rem;
    color: var(--c-bloom);
  }
</style>
