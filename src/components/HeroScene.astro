---
/**
 * Decorative National-Park-poster illustration of the Berkshire hills at dawn,
 * drawn in the blueberry palette. Pure SVG — no image download, scales cleanly.
 * When the farm supplies a real hero photograph, this can be swapped for an
 * <Image /> (see CONTENT-GUIDE.md). Decorative only.
 */
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg
  class={`hero-scene ${className}`}
  viewBox="0 0 1200 700"
  preserveAspectRatio="xMidYMid slice"
  aria-hidden="true"
  focusable="false"
>
  <defs>
    <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#2b2a5c" />
      <stop offset="0.45" stop-color="#4b4e9e" />
      <stop offset="0.8" stop-color="#8b93c9" />
      <stop offset="1" stop-color="#c8b6c2" />
    </linearGradient>
    <radialGradient id="sun" cx="0.5" cy="0.5" r="0.5">
      <stop offset="0" stop-color="#fbedd2" />
      <stop offset="0.6" stop-color="#f2c983" />
      <stop offset="1" stop-color="#e8a13a" stop-opacity="0" />
    </radialGradient>
  </defs>

  <!-- sky -->
  <rect width="1200" height="700" fill="url(#sky)" />

  <!-- sun glow + disc -->
  <circle cx="860" cy="250" r="230" fill="url(#sun)" opacity="0.85" />
  <circle cx="860" cy="250" r="74" fill="#fbedd2" opacity="0.95" />

  <!-- scattered stars in the upper sky -->
  <g fill="#e8e6f6" opacity="0.5">
    <circle cx="140" cy="70" r="1.6" />
    <circle cx="300" cy="120" r="1.2" />
    <circle cx="500" cy="60" r="1.5" />
    <circle cx="220" cy="180" r="1" />
    <circle cx="1040" cy="90" r="1.4" />
    <circle cx="1140" cy="160" r="1.1" />
  </g>

  <!-- distant ridge -->
  <path
    d="M0 430 L120 400 L260 425 L420 380 L560 415 L720 375 L880 410 L1040 385 L1200 415 L1200 700 L0 700 Z"
    fill="#3b3d84"
    opacity="0.9"
  />
  <!-- mid ridge -->
  <path
    d="M0 500 L160 470 L320 495 L500 455 L680 495 L860 460 L1040 495 L1200 470 L1200 700 L0 700 Z"
    fill="#33553b"
    opacity="0.92"
  />
  <!-- near hill -->
  <path
    d="M0 560 L200 540 L440 565 L640 535 L840 565 L1060 540 L1200 560 L1200 700 L0 700 Z"
    fill="#2c4a34"
  />

  <!-- foreground field with blueberry rows -->
  <path d="M0 610 L1200 585 L1200 700 L0 700 Z" fill="#24402c" />
  <g stroke="#1c3323" stroke-width="10" opacity="0.55" stroke-linecap="round">
    <line x1="60" y1="700" x2="230" y2="628" />
    <line x1="300" y1="700" x2="430" y2="626" />
    <line x1="560" y1="700" x2="640" y2="622" />
    <line x1="820" y1="700" x2="860" y2="620" />
    <line x1="1080" y1="700" x2="1070" y2="620" />
  </g>
  <!-- blueberry dots along the rows -->
  <g fill="#6b74b8">
    <circle cx="150" cy="655" r="6" />
    <circle cx="205" cy="640" r="5" />
    <circle cx="390" cy="650" r="6" />
    <circle cx="620" cy="645" r="5" />
    <circle cx="845" cy="643" r="6" />
    <circle cx="1068" cy="645" r="5" />
    <circle cx="700" cy="665" r="6" />
    <circle cx="480" cy="668" r="5" />
  </g>
</svg>
